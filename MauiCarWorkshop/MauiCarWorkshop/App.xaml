<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MauiCarWorkshop"
             x:Class="MauiCarWorkshop.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <Color x:Key="ColorBlack">#222831</Color>
            <Color x:Key="ColorGrey">#393E46</Color>
            <Color x:Key="ColorBlue">#00ADB5</Color>
            <Color x:Key="ColorWhite">#EEEEEE</Color>
            
            <Style x:Key="HeaderLabelStyle" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource ColorWhite}" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HorizontalOptions" Value="Center" />
            </Style>
            
            <Style x:Key="SubHeaderLabelStyle" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource ColorWhite}" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>
            
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource ColorWhite}" />
                <Setter Property="FontSize" Value="16" />
            </Style>
            
            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource ColorBlue}" />
                <Setter Property="TextColor" Value="{StaticResource ColorBlack}" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="10,5" />
            </Style>
            
            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="{StaticResource ColorGrey}" />
                <Setter Property="TextColor" Value="{StaticResource ColorWhite}" />
            </Style>
            
            <Style TargetType="Editor">
                <Setter Property="BackgroundColor" Value="{StaticResource ColorGrey}" />
                <Setter Property="TextColor" Value="{StaticResource ColorWhite}" />
                <Setter Property="AutoSize" Value="TextChanges"/>
            </Style>
            
            <Style x:Key="CardFrameStyle" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource ColorGrey}"/>
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="0,10,0,15" />
                <Setter Property="HasShadow" Value="True" />
            </Style>
            
            <Style x:Key="FieldTitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource ColorBlue}" />
            </Style> 
            
            <Style x:Key="FieldValueStyle" TargetType="Label">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="None" />
                <Setter Property="TextColor" Value="{StaticResource ColorWhite}" />
            </Style>
            
            <Style x:Key="ErrorLabel" TargetType="Label">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="TextColor" Value="Red"></Setter>
            </Style>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>
