<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiCarWorkshop.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MauiCarWorkshop"
    xmlns:pages="clr-namespace:MauiCarWorkshop.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="MauiCarWorkshop">
    
    <TabBar>
        <Tab Title="Order creation"
             
             Route="OrderCreation">
            <ShellContent ContentTemplate="{DataTemplate local:CreateOrderPage}" />
        </Tab>
        <Tab Title="Calender"
             
             Route="Calender">
            <ShellContent ContentTemplate="{DataTemplate pages:CalenderPage}" />
        </Tab>
        <Tab Title="Create invoice"
             
             Route="CreateInvoice">
            <ShellContent ContentTemplate="{DataTemplate local:CreateInvoicePage}" />
        </Tab>
        <Tab Title="See invoices"
             
             Route="SeeInvoices">
            <ShellContent ContentTemplate="{DataTemplate pages:SeeInvoicePage}" />
        </Tab>
    </TabBar>

</Shell>