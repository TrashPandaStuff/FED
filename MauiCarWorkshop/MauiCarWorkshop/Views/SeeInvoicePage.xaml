<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiCarWorkshop.ViewModels"
             xmlns:models="clr-namespace:MauiCarWorkshop.Models"
             x:Class="MauiCarWorkshop.Views.SeeInvoicePage"
             x:DataType="vm:SeeInvoiceViewModel"
             BackgroundColor="{StaticResource ColorBlack}">

    <ScrollView>
        <VerticalStackLayout Style="{StaticResource VSL}">

            <Label Text="All Invoices"
                   Style="{StaticResource HeaderLabelStyle}" />

            <CollectionView ItemsSource="{Binding Invoices}"
                            SelectionMode="None"
                            Margin="0,10,0,0">
                   <CollectionView.ItemsLayout>
                          <LinearItemsLayout Orientation="Vertical"
                                             ItemSpacing="15"
                                 ></LinearItemsLayout>
                   </CollectionView.ItemsLayout>

                   <CollectionView.EmptyView>
                    <Label Text="No invoices available"
                           HorizontalOptions="Center"
                           Margin="0,20,0,0"
                           Style="{StaticResource SubHeaderLabelStyle}" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Invoice">

                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItem Text="Delete"
                                               BackgroundColor="Red"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SeeInvoiceViewModel}}, Path=DeleteInvoiceCommand}"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Frame Style="{StaticResource CardFrameStyle}">

                                <VerticalStackLayout Spacing="6">

                                    <Label Text="Invoice ID"
                                           Style="{StaticResource FieldTitleStyle}" />
                                    <Label Text="{Binding InvoiceId, StringFormat='Invoice #{0}'}"
                                           Style="{StaticResource FieldValueStyle}" />

                                    <Label Text="Mechanic"
                                           Style="{StaticResource FieldTitleStyle}" />
                                    <Label Text="{Binding MechanicName}"
                                           Style="{StaticResource FieldValueStyle}" />

                                    <Label Text="Order ID"
                                           Style="{StaticResource FieldTitleStyle}" />
                                    <Label Text="{Binding OrderId}"
                                           Style="{StaticResource FieldValueStyle}" />

                                    <Label Text="Materials Used"
                                           Style="{StaticResource FieldTitleStyle}" />
                                    <Label Text="{Binding MaterialsUsed}"
                                           Style="{StaticResource FieldValueStyle}" />

                                    <Label Text="Material Cost"
                                           Style="{StaticResource FieldTitleStyle}" />
                                    <Label Text="{Binding MaterialCost, StringFormat='{0:C}'}"
                                           Style="{StaticResource FieldValueStyle}" />

                                    <Label Text="Hours Worked"
                                           Style="{StaticResource FieldTitleStyle}" />
                                    <Label Text="{Binding HoursWorked}"
                                           Style="{StaticResource FieldValueStyle}" />

                                    <Label Text="Hourly Rate"
                                           Style="{StaticResource FieldTitleStyle}" />
                                    <Label Text="{Binding HourlyRate, StringFormat='{0:C}'}"
                                           Style="{StaticResource FieldValueStyle}" />

                                    <Label Text="Total"
                                           Style="{StaticResource FieldTitleStyle}" />
                                    <Label Text="{Binding Total, StringFormat='{0:C}'}"
                                           Style="{StaticResource FieldValueStyle}"
                                           TextColor="Green" />

                                </VerticalStackLayout>

                            </Frame>

                        </SwipeView>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>